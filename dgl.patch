+        commands["O"] = ifnxcp "/etc/dgl-default-rcfile.nh500" "%ruserdata/%n/%n.nh500rc",
+		        exec "/bin/nano" "%ruserdata/%n/%n.nh500rc"
+        commands["p"] = play_game "nh500curses"
+	commands["P"] = play_game "nh500tty"
         commands["q"] = quit
 }
 
