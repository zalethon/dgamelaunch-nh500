-        bannerfile = "dgl_menu_main_anon.txt"
+        bannerfile = "/etc/menu/dgl_menu_main_anon.txt"
         cursor = (5,18)
         commands["l"] = ask_login
         commands["r"] = ask_register
@@ -165,7 +160,7 @@
 menu["mainmenu_user"] {
